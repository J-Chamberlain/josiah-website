---
import TagChip from './TagChip.astro';
import type { ContentEntry } from '../lib/types';
import { contentUrl } from '../lib/content-source';

interface Props {
  entry: ContentEntry;
  showCover?: boolean;
  size?: 'default' | 'wide';
  href?: string;
}

const { entry, showCover = true, size = 'default', href } = Astro.props;

const kindLabel: Record<ContentEntry['kind'], string> = {
  essay: 'Essay',
  project: 'Project',
  ideaOutline: 'Idea',
  gallery: 'Gallery',
};

const url = href ?? contentUrl(entry);
const alignValue = entry.coverImage?.align as string | undefined;
const alignFallback = alignValue === 'top' || alignValue === 'center' || alignValue === 'bottom' ? alignValue : undefined;
const coverPositionX = entry.coverImage?.positionX?.trim() || '50%';
const coverPositionY = entry.coverImage?.positionY?.trim() || alignFallback || 'center';
const coverImageStyle = `object-position: ${coverPositionX} ${coverPositionY};`;
---

<article class:list={['content-card', size === 'wide' && 'wide']}>
  {showCover && entry.coverImage && (
    <div class="card-cover">
      <img src={entry.coverImage.src} alt={entry.coverImage.alt} style={coverImageStyle} />
    </div>
  )}
  {showCover && !entry.coverImage && (
    <div class="card-cover"></div>
  )}
  <div class="card-body">
    <h3><a href={url}>{entry.title}</a></h3>
    {entry.subtitle && <p class="muted">{entry.subtitle}</p>}
    {entry.excerpt && <p>{entry.excerpt}</p>}
    {entry.tags && entry.tags.length > 0 && (
      <p class="tag-row">{entry.tags.map((tag) => <TagChip tag={tag} />)}</p>
    )}
    <p class="meta-row">{kindLabel[entry.kind]}</p>
  </div>
</article>
