---
import BaseLayout from '../layouts/BaseLayout.astro';
import TagChip from '../components/TagChip.astro';
import { contentUrl, getPublicByKind } from '../lib/content-source';

const featuredProjects = await getPublicByKind('project');
const essays = await getPublicByKind('essay');
const ideas = await getPublicByKind('ideaOutline');
const archive = [...essays, ...ideas, ...featuredProjects].sort((a, b) => (a.publishedAt < b.publishedAt ? 1 : -1));
export const prerender = true;
---

<BaseLayout
  title="Essays & Projects"
  description="Explore featured projects, essays, idea outlines, and archive content."
  path="/essays-projects"
>
  <section class="hero">
    <p class="kicker">Index</p>
    <h1>Essays & Projects</h1>
    <p class="muted">A curated editorial map of long-form pieces, mixed-media projects, and early-stage ideas.</p>
  </section>

  <section class="section section-shell" id="featured-projects">
    <div class="section-head">
      <p class="kicker">Spotlight</p>
      <h2>Featured Projects</h2>
    </div>
    <div class="list-grid">
      {featuredProjects.map((item) => (
        <article class="card mag-card">
          <h3><a href={`/projects/${item.slug}`}>{item.title}</a></h3>
          <p>{item.excerpt}</p>
          <p class="tag-row">{item.tags.map((tag) => <TagChip tag={tag} />)}</p>
          <p class="meta-row">Project</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-shell" id="essays">
    <div class="section-head">
      <h2>Essays</h2>
    </div>
    <div class="list-grid">
      {essays.map((item) => (
        <article class="card mag-card">
          <h3><a href={`/essays/${item.slug}`}>{item.title}</a></h3>
          <p>{item.excerpt}</p>
          <p class="tag-row">{item.tags.map((tag) => <TagChip tag={tag} />)}</p>
          <p class="meta-row">Essay</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-shell" id="idea-outlines">
    <div class="section-head">
      <h2>Idea Outlines</h2>
    </div>
    <div class="list-grid">
      {ideas.map((item) => (
        <article class="card mag-card">
          <h3><a href={`/ideas/${item.slug}`}>{item.title}</a></h3>
          <p>{item.excerpt}</p>
          <p class="tag-row">{item.tags.map((tag) => <TagChip tag={tag} />)}</p>
          <p class="meta-row">Idea Outline</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-shell dark" id="archive">
    <div class="section-head">
      <h2>Archive</h2>
    </div>
    <ul class="archive-list">
      {archive.map((item) => (
        <li>
          <a href={contentUrl(item)}>{item.title}</a>
          <span class="muted">{item.publishedAt}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
