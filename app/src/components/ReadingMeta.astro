---
import type { ContentEntry } from '../lib/types';

interface Props {
  publishedAt: string;
  body: ContentEntry['body'];
}

const { publishedAt, body } = Astro.props;

const formattedDate = publishedAt
  ? new Date(publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const wordCount = body
  .filter((b): b is { type: 'paragraph' | 'heading'; text: string } =>
    b.type === 'paragraph' || b.type === 'heading'
  )
  .reduce((acc, b) => acc + b.text.split(/\s+/).filter(Boolean).length, 0);

const readingTime = Math.max(1, Math.round(wordCount / 200));
---

<div class="reading-meta">
  {formattedDate && <span>{formattedDate}</span>}
  {wordCount > 0 && (
    <>
      <span class="reading-meta-sep" aria-hidden="true"></span>
      <span>{readingTime} min read</span>
    </>
  )}
</div>
