---
import type { EditorialCardItem } from '../lib/editorial';

interface Props {
  item: EditorialCardItem;
  featured?: boolean;
}

const { item, featured = false } = Astro.props;
---

<article class:list={['editorial-card', featured && 'is-featured', !item.href && 'is-static']}>
  {item.href ? (
    <a class="editorial-card__inner" href={item.href}>
      {item.imageSrc && (
        <figure class="editorial-card__media">
          <img src={item.imageSrc} alt={item.imageAlt ?? item.title} loading="lazy" />
        </figure>
      )}
      <div class="editorial-card__body">
        <p class="editorial-card__label">{item.label}</p>
        <h3>{item.title}</h3>
        <p class="editorial-card__description">{item.description}</p>
      </div>
    </a>
  ) : (
    <div class="editorial-card__inner" aria-disabled="true">
      {item.imageSrc && (
        <figure class="editorial-card__media">
          <img src={item.imageSrc} alt={item.imageAlt ?? item.title} loading="lazy" />
        </figure>
      )}
      <div class="editorial-card__body">
        <p class="editorial-card__label">{item.label}</p>
        <h3>{item.title}</h3>
        <p class="editorial-card__description">{item.description}</p>
      </div>
    </div>
  )}
</article>

<style>
  .editorial-card {
    border: 1px solid var(--rule);
    background: color-mix(in oklab, var(--surface) 94%, white 6%);
  }

  .editorial-card__inner {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .editorial-card__media {
    margin: 0;
    padding: var(--space-3) var(--space-3) 0;
  }

  .editorial-card__media img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid color-mix(in oklab, var(--rule) 82%, white 18%);
    background: color-mix(in oklab, var(--surface) 85%, white 15%);
  }

  .editorial-card__body {
    padding: var(--space-3);
  }

  .editorial-card__label {
    margin: 0 0 var(--space-2);
    color: var(--accent);
    font-family: var(--font-ui);
    font-size: 0.76rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .editorial-card h3 {
    margin-bottom: 0.45rem;
  }

  .editorial-card__description {
    margin: 0;
    color: var(--muted);
    line-height: 1.5;
  }

  .editorial-card:not(.is-static) .editorial-card__inner:hover h3 {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .editorial-card.is-featured .editorial-card__body {
    padding-top: var(--space-4);
    padding-bottom: var(--space-4);
  }

  .editorial-card.is-featured h3 {
    font-size: clamp(1.9rem, 3vw, 2.7rem);
  }

  .editorial-card.is-static {
    background: color-mix(in oklab, var(--surface) 91%, white 9%);
  }
</style>
