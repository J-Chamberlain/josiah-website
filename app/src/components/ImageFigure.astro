---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  fullWidth?: boolean;
  width?: string;
  align?: 'left' | 'center' | 'right';
  cropWidth?: number;
  cropHeight?: number;
  naturalAspect?: number;
}

const { src, alt, caption, fullWidth = false, width, align, cropWidth, cropHeight, naturalAspect } = Astro.props;

const classes = ['image-figure', fullWidth && 'full-width', align && `align-${align}`].filter(Boolean).join(' ');
const isFloat = align === 'left' || align === 'right';
const figureStyle = (width && isFloat) ? `width: ${width}; max-width: 100%` : undefined;
const imgStyle = (width && !isFloat) ? `width: ${width}; max-width: 100%` : undefined;

// Horizontal crop: show middle X% of width
const hScalePct = cropWidth ? (100 / cropWidth) * 100 : null;
const hOffsetPct = hScalePct ? (hScalePct - 100) / 2 : null;

// Vertical crop: show middle X% of height using object-fit + known aspect ratio
const croppedAspect = (cropHeight && naturalAspect) ? naturalAspect / (cropHeight / 100) : null;
const containerWidth = width ?? '100%';
---

<figure class={classes} style={figureStyle}>
  {cropHeight && croppedAspect ? (
    <div style={`aspect-ratio: ${croppedAspect}; overflow: hidden; width: ${containerWidth}; max-width: 100%;${align === 'center' ? ' margin-inline: auto;' : ''}`}>
      <img src={src} alt={alt} loading="lazy" style="width: 100%; height: 100%; object-fit: cover; object-position: center center; display: block;" />
    </div>
  ) : cropWidth ? (
    <div style="overflow: hidden; width: 100%;">
      <img src={src} alt={alt} loading="lazy" style={`width: ${hScalePct}%; margin-left: -${hOffsetPct}%; display: block;`} />
    </div>
  ) : (
    <img src={src} alt={alt} loading="lazy" style={imgStyle} />
  )}
  {caption && <figcaption>{caption}</figcaption>}
</figure>
