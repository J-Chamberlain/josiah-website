---
import TagChip from './TagChip.astro';
import ReadingMeta from './ReadingMeta.astro';
import type { ContentEntry } from '../lib/types';

interface Props {
  entry: ContentEntry;
  kicker?: string;
  commentStatus?: string | null;
}

const { entry, kicker, commentStatus } = Astro.props;
---

<header class="article-header">
  <div class="article-header-body">
    {kicker && <p class="kicker">{kicker}</p>}
    <h1>{entry.title}</h1>
    {entry.subtitle && <p class="article-subtitle">{entry.subtitle}</p>}
    {entry.coverImage && (() => {
      const ci = entry.coverImage!;
      const alignClass = ci.align ? `align-${ci.align}` : '';
      const containerWidth = ci.width ?? '100%';
      const centerMargin = ci.align === 'center' ? ' margin-inline: auto;' : '';
      const croppedAspect = (ci.cropHeight && ci.naturalAspect)
        ? ci.naturalAspect / (ci.cropHeight / 100)
        : null;
      return (
        <figure class={`article-header-cover${alignClass ? ` ${alignClass}` : ''}`}>
          {croppedAspect ? (
            <div style={`aspect-ratio: ${croppedAspect}; overflow: hidden; width: ${containerWidth}; max-width: 100%;${centerMargin}`}>
              <img src={ci.src} alt={ci.alt} style="width: 100%; height: 100%; object-fit: cover; object-position: center center; display: block;" />
            </div>
          ) : (
            <img src={ci.src} alt={ci.alt} style={ci.width ? `width: ${containerWidth}; max-width: 100%;${centerMargin}` : undefined} />
          )}
          {ci.caption && <figcaption style="text-align: center;">{ci.caption}</figcaption>}
        </figure>
      );
    })()}
    {entry.excerpt && <p class="article-dek">{entry.excerpt}</p>}
    <ReadingMeta publishedAt={entry.publishedAt} body={entry.body} />
    {entry.tags && entry.tags.length > 0 && (
      <p class="tag-row">{entry.tags.map((tag) => <TagChip tag={tag} />)}</p>
    )}
    {commentStatus && (
      <p class="note" style="margin-top: 1rem;">
        {commentStatus === 'approved'
          ? 'Comment published.'
          : commentStatus === 'rejected'
            ? 'Comment was rejected by moderation.'
            : 'Comment received and awaiting moderation.'}
      </p>
    )}
  </div>
</header>
