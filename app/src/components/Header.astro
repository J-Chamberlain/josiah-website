---
import { NAV_ITEMS, SITE_SETTINGS } from '../lib/site';
import type { SiteSettings } from '../lib/types';

const currentPath = Astro.url.pathname;
const { settings = SITE_SETTINGS } = Astro.props as { settings?: SiteSettings };
const navByLabel = new Map(NAV_ITEMS.map((item) => [item.label, item]));
const legacyLabelMap: Record<string, string[]> = {
  'Essays & Projects': ['Essays', 'Projects', 'Ideas'],
};
type NavItem = (typeof NAV_ITEMS)[number];
function isNavItem(value: NavItem | undefined): value is NavItem {
  return Boolean(value);
}
const requestedLabels =
  settings.mainNav && settings.mainNav.length > 0
    ? settings.mainNav.flatMap((label) => legacyLabelMap[label] ?? [label])
    : NAV_ITEMS.map((item) => item.label);
const mappedNavItems = requestedLabels.map((label) => navByLabel.get(label)).filter(isNavItem);
const navItems = mappedNavItems.length === NAV_ITEMS.length ? mappedNavItems : NAV_ITEMS;
---

<header class="site-header">
  <div class="shell header-shell">
    <a class="brand" href="/">
      <span class="brand-mark">{settings.siteTitle}</span>
      <span class="brand-note">Ideas Lab</span>
    </a>
    <button
      type="button"
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Open menu"
      data-nav-toggle
    >
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
    </button>
    <nav id="primary-nav" class="primary-nav" aria-label="Primary" data-nav>
      <ul class="nav-list">
        {navItems.map((item) => (
          <li>
            <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  if (toggle && nav) {
    const close = () => {
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
      nav.classList.remove('is-open');
      document.body.classList.remove('nav-open');
    };
    const open = () => {
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
      nav.classList.add('is-open');
      document.body.classList.add('nav-open');
    };
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      if (expanded) close();
      else open();
    });
    nav.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }
</script>
