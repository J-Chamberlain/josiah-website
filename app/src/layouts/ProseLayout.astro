---
import BaseLayout from './BaseLayout.astro';
import '../styles/prose.css';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  noindex?: boolean;
  dropcap?: boolean;
}

const { title, description, path, ogImage, noindex, dropcap = false } = Astro.props;
---

<BaseLayout title={title} description={description} path={path} ogImage={ogImage} noindex={noindex}>
  <article class:list={['prose', dropcap && 'prose--dropcap']}>
    <slot />
  </article>
</BaseLayout>
