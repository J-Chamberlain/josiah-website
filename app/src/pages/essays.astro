---
import BaseLayout from '../layouts/BaseLayout.astro';
import EditorialCard from '../components/EditorialCard.astro';
import { getPublicByKind } from '../lib/content';

export const prerender = true;

const essayItems = getPublicByKind('essay').map((entry) => ({
  title: entry.title,
  href: `/essays/${entry.slug}`,
  label: 'ESSAY',
  description: entry.excerpt ?? entry.subtitle ?? '',
  imageSrc: entry.coverImage?.src,
  imageAlt: entry.coverImage?.alt ?? entry.title,
}));
---

<BaseLayout
  title="Essays"
  description="Finished writing from the studio."
  path="/essays"
>
  <section class="hero">
    <p class="kicker">Essays</p>
    <h1>Finished writing only.</h1>
    <p class="muted">Published essays live here as complete pieces rather than drafts or notes.</p>
  </section>

  <section class="section essays-stack">
    {essayItems.map((item, index) => (
      <EditorialCard item={item} featured={index === 0} />
    ))}
  </section>
</BaseLayout>

<style>
  .essays-stack {
    display: grid;
    gap: 1.5rem;
  }
</style>
