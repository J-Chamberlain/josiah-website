---
export const prerender = false;

import ProseLayout from '../../layouts/ProseLayout.astro';
import RichTextRenderer from '../../components/RichTextRenderer.astro';
import ArticleHeader from '../../components/ArticleHeader.astro';
import CommentForm from '../../components/CommentForm.astro';
import CommentList from '../../components/CommentList.astro';
import SlipstreamFigure from '../../components/SlipstreamFigure.astro';
import { getPublishedBySlug } from '../../lib/content-source';
import { supabaseAdmin, hasSupabase } from '../../lib/supabase';

const { slug } = Astro.params;
const entry = await getPublishedBySlug('project', slug ?? '');
const commentStatus = Astro.url.searchParams.get('comment_status');
const headerKicker = entry?.slug === 'bridge-to-the-slipstream' ? 'Ideas' : 'Project';

if (!entry) return Astro.redirect('/404');

type CommentRow = { name: string | null; body: string; createdAt: string };
let comments: CommentRow[] = [];
if (hasSupabase && supabaseAdmin) {
  const { data } = await supabaseAdmin
    .from('comments')
    .select('name, body, created_at')
    .eq('content_type', 'project')
    .eq('content_slug', entry.slug)
    .eq('status', 'approved')
    .order('created_at', { ascending: true });
  comments = (data ?? []).map((c) => ({ name: c.name, body: c.body, createdAt: c.created_at }));
}
---

<ProseLayout
  title={entry.title}
  description={entry.excerpt}
  path={`/projects/${entry.slug}`}
  noindex={entry.visibility === 'unlisted'}
>
  <ArticleHeader entry={entry} kicker={headerKicker} commentStatus={commentStatus} />

  {entry.slug === 'bridge-to-the-slipstream' && (
    <style>
      .article-header .article-dek {
        max-width: none;
      }
    </style>
  )}

  <RichTextRenderer blocks={entry.body} />

  {entry.simulationEmbed === 'slipstream' && <SlipstreamFigure />}

  <section class="comment-shell" aria-label="Comments">
    <CommentList comments={comments} />
    <CommentForm contentType="project" contentSlug={entry.slug} returnTo={`/projects/${entry.slug}`} />
  </section>
</ProseLayout>
