      caption: "The Saboteur, combative iconoclast cluster. Focused in the wrong direction. But focused."
    },
    {
      src: "/images/geometry-of-mind/figure-10-tarot-06-joker-wide.jpg",
      alt: "The Joker, trickster chaos cluster profile.",
      caption: "The Joker, trickster chaos cluster. Chaos not as means but as end."
    },
