---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Studio Index"
  description="Legacy route for browsing essays, projects, and ideas."
  path="/essays-projects"
>
  <section class="hero">
    <p class="kicker">Studio Index</p>
    <h1>Browse by type</h1>
    <p class="muted">
      The studio is now organized into dedicated sections for essays, projects, and ideas.
    </p>
  </section>

  <section class="section legacy-links">
    <article class="section-shell">
      <h2><a href="/essays">Essays</a></h2>
      <p>Finished writing and published essays.</p>
    </article>

    <article class="section-shell">
      <h2><a href="/projects">Projects</a></h2>
      <p>Interactive and applied work, including studio tools and prototypes.</p>
    </article>

    <article class="section-shell">
      <h2><a href="/ideas">Ideas</a></h2>
      <p>Visual concepts and draft directions that are still being formed.</p>
    </article>
  </section>
</BaseLayout>

<style>
  .legacy-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-3);
  }
</style>
